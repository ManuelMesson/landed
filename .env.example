ANTHROPIC_API_KEY=
# Optional: override the default SQLite database path.
# Useful in tests to isolate state in a temporary file.
LANDED_DB_PATH=
# Optional: override where Jordan audio files are written.
# Useful in tests to keep generated files in a temp directory.
LANDED_AUDIO_DIR=
# Optional: set to 1 to skip edge_tts and write placeholder audio instead.
# Recommended for local tests and CI to avoid real TTS calls.
LANDED_DISABLE_TTS=
